            "state" : "translated",
            "value" : "Please enter a value greater than or equal to 0."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"0\" 이상의 수치를 입력해주세요."
          }
        }
      }
    },
    "500–799 ml\n" : {
