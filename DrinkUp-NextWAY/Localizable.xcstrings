      "localizations" : {
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "연속 일수:%lld일"
          }
        }
      }
    },
    "閉じる" : {
      "localizations" : {
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "닫기"
          }
        }
