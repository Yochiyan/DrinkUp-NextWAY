      "shouldTranslate" : false
    },
    "あなたの水筒で、簡単に正確な記録ができます。" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Easily and accurately track hydration with your own bottle."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "당신의 물병으로 간단하고 정확한 기록을 할 수 있습니다."
          }
